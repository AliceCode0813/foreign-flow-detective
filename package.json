{
  "name": "foreign-flow-detective",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "ingest": "py scripts/ingest.py --market ALL",
    "ingest:kospi": "py scripts/ingest.py --market KOSPI",
    "ingest:kosdaq": "py scripts/ingest.py --market KOSDAQ",
    "ingest:all": "py scripts/ingest.py --market ALL",
    "ingest:missing": "py scripts/ingest.py --market KOSPI --only-missing --days 120",
    "ingest:resume": "py scripts/ingest.py --market ALL --only-missing --with-alerts",
    "sync:stocks": "py scripts/sync_stocks.py --market ALL",
