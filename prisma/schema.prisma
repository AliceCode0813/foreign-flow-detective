// Foreign Flow Detective — PostgreSQL (Supabase 호환)
// 외국인 지분율 전용 데이터 모델

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 상장 종목 마스터
model Stock {
  code         String   @id @map("code") @db.VarChar(6)
  name         String
  market       String   @db.VarChar(20)
  sector       String?  @db.VarChar(100)
  overview     String?  @db.Text
  dartCorpCode String?  @map("dart_corp_code") @db.VarChar(8)
  createdAt    DateTime @default(now()) @map("created_at")

  ownership   ForeignOwnershipDaily[]
  rankings    RankingDaily[]
  marketDaily StockMarketDaily[]
  fundamentals StockFundamentalDaily[]
  alerts      Alert[]
  watchlist   Watchlist?
  rankingSnapshots RankingSnapshotDaily[]
  investorTrading InvestorTradingDaily[]
  investorRankings InvestorRankingDaily[]
  investorRankingSnapshots InvestorRankingSnapshotDaily[]

  @@map("stocks")
}

/// 일별 외국인 지분 스냅샷 (pykrx 수집)
model ForeignOwnershipDaily {
  id              String   @id @default(cuid())
  stockCode       String   @map("stock_code") @db.VarChar(6)
  tradeDate       String   @map("trade_date") @db.VarChar(10)
  foreignRatioPct Float    @map("foreign_ratio_pct")
  foreignShares   BigInt?  @map("foreign_shares")
  listedShares    BigInt?  @map("listed_shares")
  source          String   @default("pykrx") @db.VarChar(30)
  createdAt       DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([stockCode, tradeDate])
  @@index([stockCode, tradeDate])
  @@map("foreign_ownership_daily")
}

/// 일별 기간 변화율 (ingest 시 사전 계산)
model RankingDaily {
  id                     String   @id @default(cuid())
  stockCode              String   @map("stock_code") @db.VarChar(6)
  tradeDate              String   @map("trade_date") @db.VarChar(10)
  change1d               Float    @default(0) @map("change_1d")
  change5d               Float    @default(0) @map("change_5d")
  change20d              Float    @default(0) @map("change_20d")
  change60d              Float    @map("change_60d")
  foreignRatioPercentile Float?   @map("foreign_ratio_percentile")
  consecutiveUpDays      Int      @default(0) @map("consecutive_up_days")
  consecutiveDownDays    Int      @default(0) @map("consecutive_down_days")
  createdAt              DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([stockCode, tradeDate])
  @@index([tradeDate, change1d])
  @@index([tradeDate, change5d])
  @@index([tradeDate, change20d])
  @@index([tradeDate, change60d])
  @@index([tradeDate, consecutiveUpDays])
  @@index([tradeDate, consecutiveDownDays])
  @@map("rankings_daily")
}

/// ingest 시 사전 계산된 TOP10 랭킹 스냅샷 (웹 즉시 조회용)
model RankingSnapshotDaily {
  id                     String   @id @default(cuid())
  tradeDate              String   @map("trade_date") @db.VarChar(10)
  market                 String   @db.VarChar(20)
  period                 String   @db.VarChar(4)
  direction              String   @db.VarChar(6)
  rank                   Int
  stockCode              String   @map("stock_code") @db.VarChar(6)
  change                 Float
  currentRatio           Float    @map("current_ratio")
  foreignRatioPercentile Float?   @map("foreign_ratio_percentile")
  createdAt              DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([tradeDate, market, period, direction, rank])
  @@index([tradeDate, market, period, direction])
  @@map("rankings_snapshot_daily")
}

/// 일별 시세 (차트용: OHLCV + 등락률)
model StockMarketDaily {
  id         String   @id @default(cuid())
  stockCode  String   @map("stock_code") @db.VarChar(6)
  tradeDate  String   @map("trade_date") @db.VarChar(10)
  openPrice  Float    @default(0) @map("open_price")
  highPrice  Float    @default(0) @map("high_price")
  lowPrice   Float    @default(0) @map("low_price")
  closePrice Float    @map("close_price")
  volume     BigInt   @map("volume")
  changePct  Float    @default(0) @map("change_pct")
  createdAt  DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([stockCode, tradeDate])
  @@index([stockCode, tradeDate])
  @@map("stock_market_daily")
}

/// 일별 투자지표 (pykrx 시총·PER·PBR 등)
model StockFundamentalDaily {
  id           String   @id @default(cuid())
  stockCode    String   @map("stock_code") @db.VarChar(6)
  tradeDate    String   @map("trade_date") @db.VarChar(10)
  marketCap    BigInt   @map("market_cap")
  listedShares BigInt   @map("listed_shares")
  tradingValue BigInt?  @map("trading_value")
  per          Float?
  pbr          Float?
  eps          Float?
  bps          Float?
  divYield     Float?   @map("div_yield")
  dps          Float?
  createdAt    DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([stockCode, tradeDate])
  @@index([stockCode, tradeDate])
  @@map("stock_fundamental_daily")
}

/// 알림 엔진 출력 (Priority 5)
model Alert {
  id        String   @id @default(cuid())
  stockCode String   @map("stock_code") @db.VarChar(6)
  alertType String   @map("alert_type") @db.VarChar(50)
  message   String
  tradeDate String   @map("trade_date") @db.VarChar(10)
  severity  String   @default("info") @db.VarChar(20)
  payload   Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@index([stockCode, tradeDate])
  @@index([createdAt])
  @@index([alertType])
  @@map("alerts")
}

/// 일별 투자자별 순매수거래대금 (pykrx 수집)
model InvestorTradingDaily {
  id           String   @id @default(cuid())
  stockCode    String   @map("stock_code") @db.VarChar(6)
  tradeDate    String   @map("trade_date") @db.VarChar(10)
  investorType String   @map("investor_type") @db.VarChar(20)
  netValue     BigInt   @map("net_value")
  source       String   @default("pykrx") @db.VarChar(30)
  createdAt    DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([stockCode, tradeDate, investorType])
  @@index([stockCode, tradeDate])
  @@index([tradeDate, investorType])
  @@map("investor_trading_daily")
}

/// 투자자별 기간 순매수 합계 (ingest 시 사전 계산)
model InvestorRankingDaily {
  id                  String   @id @default(cuid())
  stockCode           String   @map("stock_code") @db.VarChar(6)
  tradeDate           String   @map("trade_date") @db.VarChar(10)
  investorType        String   @map("investor_type") @db.VarChar(20)
  change1d            BigInt   @default(0) @map("change_1d")
  change5d            BigInt   @default(0) @map("change_5d")
  change20d           BigInt   @default(0) @map("change_20d")
  change60d           BigInt   @map("change_60d")
  consecutiveUpDays   Int      @default(0) @map("consecutive_up_days")
  consecutiveDownDays Int      @default(0) @map("consecutive_down_days")
  createdAt           DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([stockCode, tradeDate, investorType])
  @@index([tradeDate, investorType, change1d])
  @@index([tradeDate, investorType, change5d])
  @@index([tradeDate, investorType, change20d])
  @@index([tradeDate, investorType, change60d])
  @@index([tradeDate, investorType, consecutiveUpDays], map: "investor_rankings_daily_consecutive_up_idx")
  @@index([tradeDate, investorType, consecutiveDownDays], map: "investor_rankings_daily_consecutive_down_idx")
  @@map("investor_rankings_daily")
}

/// 투자자별 TOP10 랭킹 스냅샷 (웹 즉시 조회용)
model InvestorRankingSnapshotDaily {
  id           String   @id @default(cuid())
  tradeDate    String   @map("trade_date") @db.VarChar(10)
  market       String   @db.VarChar(20)
  period       String   @db.VarChar(4)
  direction    String   @db.VarChar(6)
  investorType String   @map("investor_type") @db.VarChar(20)
  rank         Int
  stockCode    String   @map("stock_code") @db.VarChar(6)
  change       BigInt
  currentValue BigInt   @map("current_value")
  createdAt    DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@unique([tradeDate, market, period, direction, investorType, rank])
  @@index([tradeDate, market, period, direction, investorType])
  @@map("investor_rankings_snapshot_daily")
}

/// 사용자 즐겨찾기 (관심 종목)
model Watchlist {
  stockCode String   @id @map("stock_code") @db.VarChar(6)
  createdAt DateTime @default(now()) @map("created_at")

  stock Stock @relation(fields: [stockCode], references: [code], onDelete: Cascade)

  @@map("watchlist")
}
